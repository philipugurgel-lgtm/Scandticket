{
  "name": "scandticket/core",
  "description": "Enterprise ticket scanning and QR validation for WordPress.",
  "type": "wordpress-plugin",
  "license": "GPL-2.0-or-later",
  "require": {
    "php": ">=8.1",
    "cboden/ratchet": "^0.4.4",
    "react/event-loop": "^1.5",
    "clue/redis-react": "^2.7"
  },
  "autoload": {
    "psr-4": {
      "ScandTicket\\": "src/",
      "ScandTicket\\Tests\\": "tests/"
    }
  },
  "require-dev": {
    "phpunit/phpunit": "^10.0"
  },
  "config": {
    "optimize-autoloader": true,
    "sort-packages": true
  }
}